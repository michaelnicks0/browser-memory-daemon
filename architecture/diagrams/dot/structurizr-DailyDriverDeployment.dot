digraph {
  compound=true
  graph [fontname="Arial", rankdir=TB, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">Deployment View: Browser Memory Daemon - Daily-driver local</font>>

  subgraph cluster_85 {
    margin=25
    label=<<font point-size="24">Local workstation</font><br /><font point-size="19">[Deployment Node: Windows + WSL2]</font>>
    labelloc=b
    color="#444444"
    fontcolor="#444444"
    fillcolor="#ffffff"

    subgraph cluster_86 {
      margin=25
      label=<<font point-size="24">Windows user profile</font><br /><font point-size="19">[Deployment Node: Windows profile]</font>>
      labelloc=b
      color="#444444"
      fontcolor="#444444"
      fillcolor="#ffffff"

      subgraph cluster_87 {
        margin=25
        label=<<font point-size="24">Windows Chrome daily-driver profile</font><br /><font point-size="19">[Deployment Node: Google Chrome MV3]</font>>
        labelloc=b
        color="#444444"
        fontcolor="#444444"
        fillcolor="#ffffff"

        88 [id=88,shape=rect, label=<<font point-size="34">Chrome MV3 Extension</font><br /><font point-size="19">[Container: JavaScript, Chrome Manifest V3]</font><br /><br /><font point-size="24">Captures visible page text,<br />media references, tab<br />lifecycle events, and<br />browser-side media bytes from<br />Windows Chrome; queues work<br />durably and posts to the WSL<br />daemon.</font>>, style=filled, color="#2e6295", fillcolor="#438dd5", fontcolor="#ffffff"]
        89 [id=89,shape=cylinder, label=<<font point-size="34">Extension Browser<br />Storage</font><br /><font point-size="19">[Container: chrome.storage.local + IndexedDB]</font><br /><br /><font point-size="24">Browser-side storage for<br />capture and visit queues in<br />chrome.storage.local plus<br />durable media tasks and<br />fetched blobs in IndexedDB.</font>>, style=filled, color="#20688c", fillcolor="#2f95c8", fontcolor="#ffffff"]
        91 [id=91,shape=rect, label=<<font point-size="34">Local Web UI</font><br /><font point-size="19">[Container: HTML/CSS/JavaScript served by daemon]</font><br /><br /><font point-size="24">Static browser UI for exact<br />search, recent/timeline views,<br />document/snapshot detail,<br />media artifact opening, policy<br />rules, doctor, and<br />forget-domain operations.</font>>, style=filled, color="#2e6295", fillcolor="#438dd5", fontcolor="#ffffff"]
      }

    }

    subgraph cluster_93 {
      margin=25
      label=<<font point-size="24">WSL2 Ubuntu</font><br /><font point-size="19">[Deployment Node: Ubuntu + systemd --user]</font>>
      labelloc=b
      color="#444444"
      fontcolor="#444444"
      fillcolor="#ffffff"

      subgraph cluster_102 {
        margin=25
        label=<<font point-size="24">WSL XDG runtime data paths</font><br /><font point-size="19">[Deployment Node: WSL filesystem]</font>>
        labelloc=b
        color="#444444"
        fontcolor="#444444"
        fillcolor="#ffffff"

        103 [id=103,shape=cylinder, label=<<font point-size="34">SQLite + FTS5<br />Database</font><br /><font point-size="19">[Container: SQLite with FTS5]</font><br /><br /><font point-size="24">Durable relational and<br />full-text store for sources,<br />documents, visits, visit<br />events, snapshots, chunks,<br />chunks_fts, media artifacts,<br />media fetch tasks, policy<br />rules, audit events, and<br />deletion receipts.</font>>, style=filled, color="#20688c", fillcolor="#2f95c8", fontcolor="#ffffff"]
        107 [id=107,shape=cylinder, label=<<font point-size="34">Clean Text Blob Store</font><br /><font point-size="19">[Container: WSL filesystem]</font><br /><br /><font point-size="24">Filesystem store for snapshot<br />text blobs under WSL XDG data<br />paths.</font>>, style=filled, color="#20688c", fillcolor="#2f95c8", fontcolor="#ffffff"]
        109 [id=109,shape=cylinder, label=<<font point-size="34">Media Blob Cache</font><br /><font point-size="19">[Container: WSL filesystem]</font><br /><br /><font point-size="24">Bounded and disposable<br />filesystem cache for stored<br />image/video/audio blobs with<br />purge and rehydrate semantics.</font>>, style=filled, color="#20688c", fillcolor="#2f95c8", fontcolor="#ffffff"]
      }

      subgraph cluster_94 {
        margin=25
        label=<<font point-size="24">systemd --user services</font><br /><font point-size="19">[Deployment Node: systemd --user]</font>>
        labelloc=b
        color="#444444"
        fontcolor="#444444"
        fillcolor="#ffffff"

        95 [id=95,shape=rect, label=<<font point-size="34">WSL Loopback HTTP<br />Daemon</font><br /><font point-size="19">[Container: Python 3.11, ThreadingHTTPServer]</font><br /><br /><font point-size="24">Authenticated loopback HTTP<br />API that handles capture,<br />visit events, media artifact<br />upload/fetch/purge, exact<br />search,<br />recent/timeline/detail, policy<br />rules, doctor, forget, and<br />static UI serving.</font>>, style=filled, color="#2e6295", fillcolor="#438dd5", fontcolor="#ffffff"]
        98 [id=98,shape=rect, label=<<font point-size="34">WSL Media Worker</font><br /><font point-size="19">[Container: Python 3.11 CLI loop]</font><br /><br /><font point-size="24">Long-running systemd user<br />worker that leases<br />daemon-public media fetch<br />tasks, fetches public<br />media/HLS without Chrome<br />cookies, classifies terminal<br />states, and updates artifact<br />rows.</font>>, style=filled, color="#2e6295", fillcolor="#438dd5", fontcolor="#ffffff"]
      }

      subgraph cluster_99 {
        margin=25
        label=<<font point-size="24">WSL shell</font><br /><font point-size="19">[Deployment Node: Bash + Python]</font>>
        labelloc=b
        color="#444444"
        fontcolor="#444444"
        fillcolor="#ffffff"

        100 [id=100,shape=rect, label=<<font point-size="34">CLI</font><br /><font point-size="19">[Container: Python argparse]</font><br /><br /><font point-size="24">Command-line interface for<br />serving the daemon,<br />health/doctor/search/recent/timeline/detail,<br />policy/forget, capture<br />fixtures, media worker, and<br />media cache operations.</font>>, style=filled, color="#2e6295", fillcolor="#438dd5", fontcolor="#ffffff"]
      }

    }

  }

  100 -> 95 [id=101, label=<<font point-size="24">Calls health, read, admin,<br />capture-fixture, and<br />forget APIs on</font><br /><font point-size="19">[HTTP/JSON]</font>>, style="dashed", color="#444444", fontcolor="#444444"]
  95 -> 103 [id=104, label=<<font point-size="24">Reads and writes metadata,<br />FTS, tasks, audit, and<br />receipts in</font><br /><font point-size="19">[sqlite3]</font>>, style="dashed", color="#444444", fontcolor="#444444"]
  98 -> 103 [id=105, label=<<font point-size="24">Leases and updates media<br />tasks in</font><br /><font point-size="19">[sqlite3]</font>>, style="dashed", color="#444444", fontcolor="#444444"]
  100 -> 103 [id=106, label=<<font point-size="24">Runs media-worker and<br />media-cache commands<br />against</font><br /><font point-size="19">[sqlite3]</font>>, style="dashed", color="#444444", fontcolor="#444444"]
  95 -> 107 [id=108, label=<<font point-size="24">Reads and writes text<br />snapshots in</font><br /><font point-size="19">[Filesystem]</font>>, style="dashed", color="#444444", fontcolor="#444444"]
  95 -> 109 [id=110, label=<<font point-size="24">Stores, serves, purges,<br />and rehydrates media blobs<br />in</font><br /><font point-size="19">[Filesystem]</font>>, style="dashed", color="#444444", fontcolor="#444444"]
  98 -> 109 [id=111, label=<<font point-size="24">Writes fetched media blobs<br />to</font><br /><font point-size="19">[Filesystem]</font>>, style="dashed", color="#444444", fontcolor="#444444"]
  100 -> 109 [id=112, label=<<font point-size="24">Purges and rehydrates<br />media blobs through</font><br /><font point-size="19">[Filesystem]</font>>, style="dashed", color="#444444", fontcolor="#444444"]
  88 -> 89 [id=90, label=<<font point-size="24">Queues captures, lifecycle<br />events, media tasks, and<br />blobs in</font><br /><font point-size="19">[chrome.storage.local + IndexedDB]</font>>, style="dashed", color="#444444", fontcolor="#444444"]
  88 -> 95 [id=96, label=<<font point-size="24">Posts captures, events,<br />media metadata, and raw<br />blobs to</font><br /><font point-size="19">[Bearer HTTP/JSON; raw HTTP PUT over 127.0.0.1:8765]</font>>, style="dashed", color="#444444", fontcolor="#444444"]
  91 -> 95 [id=97, label=<<font point-size="24">Calls authenticated read,<br />admin, media, and forget<br />APIs on</font><br /><font point-size="19">[HTTP/JSON]</font>>, style="dashed", color="#444444", fontcolor="#444444"]

}