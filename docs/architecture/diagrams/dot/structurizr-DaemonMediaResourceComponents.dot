digraph {
  compound=true
  graph [fontname="Arial", rankdir=LR, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">Component View: Browser Memory Daemon - WSL Loopback HTTP Daemon</font>>

  subgraph cluster_4 {
    margin=25
    label=<<font point-size="24"><br />Browser Memory Daemon</font><br /><font point-size="19">[Software System]</font>>
    labelloc=b
    color="#444444"
    fontcolor="#444444"
    fillcolor="#444444"

    subgraph cluster_22 {
      margin=25
      label=<<font point-size="24"><br />WSL Loopback HTTP Daemon</font><br /><font point-size="19">[Container: Python 3.11, ThreadingHTTPServer]</font>>
      labelloc=b
      color="#444444"
      fontcolor="#444444"
      fillcolor="#444444"

      23 [id=23,shape=rect, label=<<font point-size="34">HTTP Request Router</font><br /><font point-size="19">[Component: Python http.server + route descriptors]</font><br /><br /><font point-size="24">Matches immutable method/path<br />descriptors with static<br />precedence, maps typed<br />compatible errors, applies<br />opaque request IDs and common<br />security headers, emits<br />redaction-safe<br />route/status/latency<br />telemetry, streams media in<br />bounded chunks with disconnect<br />cleanup, serves UI assets,<br />enforces bearer auth for<br />memory/admin APIs, and applies<br />CORS for allowed origins.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      29 [id=29,shape=rect, label=<<font point-size="34">Media Artifact<br />Manager</font><br /><font point-size="19">[Component: Python + sqlite3 + filesystem]</font><br /><br /><font point-size="24">Provides the compatibility<br />API, records media references,<br />streams bounded blob uploads,<br />delegates guarded public<br />transport, and drains verified<br />spool bytes without coupling<br />text ingest to media<br />availability.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      31 [id=31,shape=rect, label=<<font point-size="34">Media Task Repository</font><br /><font point-size="19">[Component: Python + sqlite3]</font><br /><br /><font point-size="24">Creates deterministic tasks,<br />preserves terminal state,<br />atomically leases due work,<br />recovers stale leases, and<br />applies bounded retry/backoff<br />outcomes independently from<br />media transport.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      32 [id=32,shape=rect, label=<<font point-size="34">Media Artifact Store</font><br /><font point-size="19">[Component: Python + sqlite3 + BlobStore]</font><br /><br /><font point-size="24">Owns artifact rows,<br />transactional cross-process<br />cache reservations, unique<br />streamed publication,<br />failed-write compensation,<br />contained reads, cache<br />admission, oldest-first<br />eviction, purge/rehydration,<br />and lifecycle<br />registration/tombstones.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      33 [id=33,shape=rect, label=<<font point-size="34">Media Transport<br />Coordinator</font><br /><font point-size="19">[Component: Python]</font><br /><br /><font point-size="24">Classifies direct versus HLS<br />responses, applies the<br />aggregate HLS request budget<br />from the first network open,<br />enforces playlist sniffing and<br />byte caps, and coordinates<br />bounded streamed assembly.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      34 [id=34,shape=rect, label=<<font point-size="34">Guarded Media Fetch</font><br /><font point-size="19">[Component: Python stdlib urllib + socket]</font><br /><br /><font point-size="24">Owns streamed HTTP/data<br />transport, public-address<br />validation, redirect<br />revalidation, no-referrer<br />requests, response-byte<br />limits, process request/byte<br />leases, and shared deadlines.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      35 [id=35,shape=rect, label=<<font point-size="34">Bounded HLS Transport</font><br /><font point-size="19">[Component: Python]</font><br /><br /><font point-size="24">Parses bounded playlists,<br />selects variants, expands init<br />maps/segments through the<br />guarded fetch boundary, and<br />streams assembly within<br />aggregate<br />byte/depth/request/deadline<br />limits.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      37 [id=37,shape=rect, label=<<font point-size="34">Media Process<br />Resource Budget</font><br /><font point-size="19">[Component: Python threading.Condition]</font><br /><br /><font point-size="24">Bounds active media requests<br />and in-flight bytes across<br />threads within one daemon or<br />worker process; exposes<br />aggregate counters and<br />releases leases on failure or<br />cancellation.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      38 [id=38,shape=rect, label=<<font point-size="34">Contained BlobStore</font><br /><font point-size="19">[Component: Python filesystem boundary]</font><br /><br /><font point-size="24">Prefers root-relative locators<br />with contained legacy<br />fallback; streams unique<br />stages with size/hash<br />accounting; atomically<br />commits; and contains blob<br />read, stat, and delete<br />operations.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
    }

    47 [id=47,shape=cylinder, label=<<font point-size="34">SQLite + FTS5<br />Database</font><br /><font point-size="19">[Container: SQLite with FTS5]</font><br /><br /><font point-size="24">Durable complete cleaned-text,<br />relational, and full-text<br />authority for migration<br />ledger, sources, documents,<br />visits, capture observations,<br />URL claims, visit events,<br />snapshots, chunks, chunks_fts,<br />media provenance/tasks, blob<br />lifecycle records, policy<br />rules, audit events, and<br />deletion receipts.</font>>, style=filled, color="#20688c", fillcolor="#2f95c8", fontcolor="#ffffff"]
  }

  23 -> 29 [id=118, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Routes media requests to</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  23 -> 37 [id=119, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Leases bounded media<br />upload and response<br />capacity through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  29 -> 31 [id=128, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Creates and claims durable<br />media work through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  29 -> 32 [id=129, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Publishes, resolves,<br />purges, and rehydrates<br />artifacts through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  29 -> 33 [id=130, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Delegates daemon-public<br />media orchestration to</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  29 -> 47 [id=131, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Updates media artifact<br />rows in</font><br /><font point-size="19">[sqlite3]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  31 -> 47 [id=133, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Creates, leases, and<br />advances media tasks in</font><br /><font point-size="19">[sqlite3]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  32 -> 31 [id=135, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Marks stored/skipped<br />outcomes and ensures<br />retryable fetch work<br />through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  32 -> 47 [id=136, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reserves cache capacity<br />and advances media<br />artifact rows<br />transactionally in</font><br /><font point-size="19">[sqlite3]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  32 -> 38 [id=137, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Stages unique candidates,<br />resolves contained reads,<br />and deletes failed<br />candidates through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  33 -> 34 [id=139, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Streams the initial<br />response and every direct<br />artifact through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  33 -> 35 [id=140, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Delegates detected<br />playlists for bounded<br />parsing and assembly to</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  33 -> 37 [id=141, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Leases aggregate transfer<br />bytes through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  34 -> 37 [id=142, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Leases each active HTTP<br />request through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  35 -> 34 [id=145, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Fetches every variant,<br />init map, and segment<br />through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
