digraph {
  compound=true
  graph [fontname="Arial", rankdir=LR, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">System Context View: Browser Memory Daemon</font>>

  1 [id=1,shape=rect, label=<<font point-size="34">Operator</font><br /><font point-size="19">[Person]</font><br /><br /><font point-size="24">Sole local operator who<br />browses with Windows Chrome<br />and searches, reviews, and<br />deletes local browser-memory<br />records.</font>>, style=filled, color="#052e56", fillcolor="#08427b", fontcolor="#ffffff"]
  2 [id=2,shape=rect, label=<<font point-size="34">Windows Chrome</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">The Windows Chrome runtime<br />that loads web pages, hosts<br />the MV3 extension, runs the<br />local UI in a tab, and exposes<br />Chrome extension APIs.</font>>, style=filled, color="#6b6b6b", fillcolor="#999999", fontcolor="#ffffff"]
  3 [id=3,shape=rect, label=<<font point-size="34">Web Sites and Media<br />Origins</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">External web pages,<br />image/video URLs, and media<br />CDNs that Chrome loads or that<br />sidecars fetch as page-related<br />media.</font>>, style=filled, color="#6b6b6b", fillcolor="#999999", fontcolor="#ffffff"]
  4 [id=4,shape=rect, label=<<font point-size="34">Browser Memory Daemon</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Local-first personal recall<br />system that captures Windows<br />Chrome page text and media<br />references, stores them in<br />WSL, and exposes exact search,<br />timeline, detail, deletion,<br />diagnostics, and media cache<br />operations.</font>>, style=filled, color="#0b4884", fillcolor="#1168bd", fontcolor="#ffffff"]

  1 -> 2 [id=34, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Browses web pages with</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  1 -> 4 [id=35, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Searches, reviews, and<br />deletes local browser<br />memory through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  2 -> 3 [id=36, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Loads pages and media from</font><br /><font point-size="19">[HTTPS]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  4 -> 2 [id=37, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Runs its MV3 extension<br />inside and uses APIs from</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  4 -> 3 [id=38, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Captures page refs and<br />fetches browser-side or<br />public media from</font><br /><font point-size="19">[Chrome DOM/fetch; WSL HTTP(S), data URLs; no Chrome cookies in WSL]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]

}