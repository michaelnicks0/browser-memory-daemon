digraph {
  compound=true
  graph [fontname="Arial", rankdir=LR, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">Browser Memory Daemon - System Context</font>>

  1 [id=1,shape=rect, label=<<font point-size="34">Operator</font><br /><font point-size="19">[Person]</font><br /><br /><font point-size="24">Sole local operator who<br />browses with Windows<br />Chrome and searches,<br />reviews, and deletes local<br />browser-memory records.</font>>, style=filled, color="#052e56", fillcolor="#08427b", fontcolor="#ffffff"]
  2 [id=2,shape=rect, label=<<font point-size="34">Windows Chrome</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">The Windows Chrome runtime<br />that loads web pages, hosts<br />the MV3 extension, runs the<br />local UI in a tab, and exposes<br />Chrome extension APIs.</font>>, style=filled, color="#6b6b6b", fillcolor="#999999", fontcolor="#ffffff"]
  3 [id=3,shape=rect, label=<<font point-size="34">Web Sites and Media<br />Origins</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">External web pages,<br />image/video URLs, and media<br />CDNs that Chrome loads or that<br />sidecars fetch as page-related<br />media.</font>>, style=filled, color="#6b6b6b", fillcolor="#999999", fontcolor="#ffffff"]
  4 [id=4,shape=rect, label=<<font point-size="34">Passive X Observation<br />Consumer</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">A downstream local integration<br />that reads versioned body-safe<br />observation pages without<br />gaining capture, migration, or<br />mutation authority.</font>>, style=filled, color="#6b6b6b", fillcolor="#999999", fontcolor="#ffffff"]
  5 [id=5,shape=rect, label=<<font point-size="34">Browser Memory Daemon</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">Local-first personal recall<br />system that captures Windows<br />Chrome page text/media and<br />exports versioned body-safe X<br />observations.</font>>, style=filled, color="#0b4884", fillcolor="#1168bd", fontcolor="#ffffff"]

  1 -> 2 [id=63, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Browses web pages with</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  1 -> 5 [id=64, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Searches, reviews, and<br />deletes local browser<br />memory through</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  2 -> 3 [id=66, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Loads pages and media from</font><br /><font point-size="19">[HTTPS]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  4 -> 5 [id=68, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads authenticated<br />versioned body-safe<br />observation pages from</font><br /><font point-size="19">[HTTP/JSON]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  5 -> 2 [id=69, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Runs its MV3 extension<br />inside and uses APIs from</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  5 -> 3 [id=70, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Captures page refs and<br />fetches browser-side or<br />public media from</font><br /><font point-size="19">[Chrome DOM/fetch; WSL HTTP(S), data URLs; no Chrome cookies in WSL]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  5 -> 4 [id=82, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Emits versioned body-safe<br />observation pages for</font><br /><font point-size="19">[JSON stdout]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
}