digraph {
  compound=true
  graph [fontname="Arial", rankdir=LR, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">Browser Memory Daemon - CLI - Components</font>>

  57 [id=57,shape=cylinder, label=<<font point-size="34">SQLite + FTS5<br />Database</font><br /><font point-size="19">[Container: SQLite with FTS5]</font><br /><br /><font point-size="24">Durable text/metadata<br />authority including migration<br />ledger, capture observations,<br />and immutable observation<br />ingest sequences.</font>>, style=filled, color="#20688c", fillcolor="#2f95c8", fontcolor="#ffffff"]
  58 [id=58,shape=cylinder, label=<<font point-size="34">Local Derivative<br />Store</font><br /><font point-size="19">[Container: WSL local filesystem]</font><br /><br /><font point-size="24">Reconstructible compatibility<br />evidence such as pre-version-9<br />clean-text sidecars; new<br />captures create no text<br />sidecars.</font>>, style=filled, color="#20688c", fillcolor="#2f95c8", fontcolor="#ffffff"]
  61 [id=61,shape=cylinder, label=<<font point-size="34">Local Backup Bundles</font><br /><font point-size="19">[Container: Local filesystem]</font><br /><br /><font point-size="24">Operator-selected local<br />directories containing an<br />online SQLite snapshot,<br />redaction-safe hash manifest,<br />and optional referenced<br />derivatives; media, spool, and<br />secrets excluded by default.</font>>, style=filled, color="#20688c", fillcolor="#2f95c8", fontcolor="#ffffff"]
  62 [id=62,shape=cylinder, label=<<font point-size="34">Restored Runtime Root</font><br /><font point-size="19">[Container: Local filesystem]</font><br /><br /><font point-size="24">An explicit absent destination<br />that is privately staged,<br />manifest/schema/semantic<br />verified, and atomically<br />published with restored SQLite<br />authority and optional<br />referenced derivatives only.</font>>, style=filled, color="#20688c", fillcolor="#2f95c8", fontcolor="#ffffff"]

  subgraph cluster_51 {
    margin=25
    label=<<font point-size="24"><br />CLI</font><br /><font point-size="19">[Container: Python argparse]</font>>
    labelloc=b
    color="#444444"
    fontcolor="#444444"
    fillcolor="#444444"

    56 [id=56,shape=rect, label=<<font point-size="34">Backup and Restore<br />Operator</font><br /><font point-size="19">[Component: Python sqlite3 + filesystem]</font><br /><br /><font point-size="24">Creates dry-run-first SQLite<br />online backup bundles with<br />redaction-safe SHA-256<br />manifests and verifies them<br />into absent runtime roots;<br />optionally carries referenced<br />derivatives and excludes API<br />token/config, Chrome<br />profile/extension copy, media<br />cache, and spool.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
  }

  56 -> 57 [id=187, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Creates and validates<br />online SQLite snapshots<br />from</font><br /><font point-size="19">[sqlite3 backup API]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  56 -> 58 [id=188, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Optionally copies<br />referenced contained<br />derivatives from</font><br /><font point-size="19">[Filesystem]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  56 -> 61 [id=190, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Atomically publishes and<br />verifies manifests/files<br />in</font><br /><font point-size="19">[Filesystem + SHA-256]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  56 -> 62 [id=191, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Stages, validates, and<br />atomically publishes<br />verified restore output in</font><br /><font point-size="19">[Filesystem + SHA-256]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
}