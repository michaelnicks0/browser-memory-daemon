digraph {
  compound=true
  graph [fontname="Arial", rankdir=TB, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">Browser Memory Daemon - Chrome MV3 Extension - Components</font>>

  2 [id=2,shape=rect, label=<<font point-size="34">Windows Chrome</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">The Windows Chrome runtime<br />that loads web pages, hosts<br />the MV3 extension, runs the<br />local UI in a tab, and exposes<br />Chrome extension APIs.</font>>, style=filled, color="#6b6b6b", fillcolor="#999999", fontcolor="#ffffff"]
  21 [id=21,shape=cylinder, label=<<font point-size="34">Extension Browser<br />Storage</font><br /><font point-size="19">[Container: chrome.storage.local + IndexedDB]</font><br /><br /><font point-size="24">Browser-side IndexedDB storage<br />for transactional<br />capture/lifecycle outbox rows<br />plus specialized durable media<br />tasks/blobs;<br />chrome.storage.local retains<br />typed configuration, lifecycle<br />tab state, minimal CDP capture<br />context, aggregate telemetry,<br />and one-version queue fallback<br />only.</font>>, style=filled, color="#20688c", fillcolor="#2f95c8", fontcolor="#ffffff"]
  22 [id=22,shape=rect, label=<<font point-size="34">WSL Loopback HTTP<br />Daemon</font><br /><font point-size="19">[Container: Python 3.11, ThreadingHTTPServer]</font><br /><br /><font point-size="24">Authenticated loopback API for<br />capture, read/admin/media<br />operations, and query-only<br />bmd.x-observations v1 export.</font>>, style=filled, color="#2e6295", fillcolor="#438dd5", fontcolor="#ffffff"]

  subgraph cluster_5 {
    margin=25
    label=<<font point-size="24"><br />Chrome MV3 Extension</font><br /><font point-size="19">[Container: JavaScript, Chrome Manifest V3]</font>>
    labelloc=b
    color="#444444"
    fontcolor="#444444"
    fillcolor="#444444"

    10 [id=10,shape=rect, label=<<font point-size="34">Extension Config<br />Store</font><br /><font point-size="19">[Component: JavaScript + chrome.storage.local]</font><br /><br /><font point-size="24">Owns typed configuration<br />defaults/migration plus<br />durable visit and minimal CDP<br />capture-context maps.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
    13 [id=13,shape=rect, label=<<font point-size="34">Capture and Lifecycle<br />Bridge</font><br /><font point-size="19">[Component: JavaScript]</font><br /><br /><font point-size="24">Owns daemon delivery,<br />transactional outbox<br />import/admission/drain/checkpoint/retry,<br />legacy fallback, media<br />compensation, and queue<br />status.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
    14 [id=14,shape=rect, label=<<font point-size="34">Credentialed Media<br />Bridge</font><br /><font point-size="19">[Component: JavaScript]</font><br /><br /><font point-size="24">Owns browser credentialed<br />fetch, inline/CDP blob upload,<br />specialized media queue<br />drain/retry, and terminal<br />cleanup.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
    15 [id=15,shape=rect, label=<<font point-size="34">Extension Telemetry</font><br /><font point-size="19">[Component: JavaScript + chrome.storage.local]</font><br /><br /><font point-size="24">Persists aggregate<br />bridge/queue/CDP status after<br />recursively removing captured<br />fields and redacting<br />URL-shaped errors.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
    17 [id=17,shape=rect, label=<<font point-size="34">Browser Media Queue<br />Adapter</font><br /><font point-size="19">[Component: JavaScript + IndexedDB]</font><br /><br /><font point-size="24">Persists media tasks and<br />fetched blobs in versioned<br />IndexedDB with atomic<br />batch/blob transitions,<br />count/byte quotas,<br />stale-processing recovery, and<br />bounded terminal quarantine<br />cleanup.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
    18 [id=18,shape=rect, label=<<font point-size="34">CDP Recorder</font><br /><font point-size="19">[Component: Chrome DevTools Protocol]</font><br /><br /><font point-size="24">Classifies configured<br />X/Twitter video.twimg.com HLS<br />manifests and media segments<br />before they become opaque blob<br />player URLs.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
    19 [id=19,shape=rect, label=<<font point-size="34">CDP Session<br />Controller</font><br /><font point-size="19">[Component: JavaScript + chrome.debugger]</font><br /><br /><font point-size="24">Restores minimal capture<br />provenance, reconciles<br />debugger attachments,<br />correlates Network events,<br />retrieves bounded bodies, and<br />dispatches media across MV3<br />worker restarts.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
    9 [id=9,shape=rect, label=<<font point-size="34">Service Worker</font><br /><font point-size="19">[Component: JavaScript MV3 service worker]</font><br /><br /><font point-size="24">Composes extension modules and<br />registers MV3 message, tab,<br />window, debugger, alarm,<br />startup, and installation<br />listeners.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
  }

  14 -> 17 [id=101, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Persists and drains media<br />work through</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  14 -> 22 [id=102, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Delivers media metadata<br />and raw blobs to</font><br /><font point-size="19">[Bearer HTTP/JSON; raw HTTP PUT]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  14 -> 15 [id=104, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Records aggregate media<br />status through</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  17 -> 21 [id=105, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads and writes media<br />tasks/blobs in</font><br /><font point-size="19">[IndexedDB]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  15 -> 21 [id=106, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Persists sanitized<br />aggregate status in</font><br /><font point-size="19">[chrome.storage.local]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  9 -> 19 [id=107, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Delegates debugger<br />attachment, event<br />correlation, and restart<br />reconciliation to</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  19 -> 10 [id=108, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Persists minimal per-tab<br />capture context through</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  19 -> 18 [id=109, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Uses configured<br />media-response<br />classification from</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  19 -> 14 [id=110, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Dispatches bounded CDP<br />media rows and bodies<br />through</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  19 -> 15 [id=111, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Records sanitized debugger<br />status through</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  18 -> 2 [id=112, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Classifies Network events<br />received through</font><br /><font point-size="19">[chrome.debugger/CDP]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  9 -> 10 [id=86, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads typed settings and<br />durable restart state<br />through</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  10 -> 21 [id=89, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads and writes typed<br />settings and restart state<br />in</font><br /><font point-size="19">[chrome.storage.local]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  9 -> 13 [id=92, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Delegates<br />capture/lifecycle delivery<br />and durable drains to</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  9 -> 14 [id=93, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Delegates credentialed<br />media delivery and durable<br />drains to</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  9 -> 15 [id=94, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Creates the redaction-safe<br />telemetry boundary through</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  13 -> 21 [id=96, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Imports and preserves the<br />one-version queue fallback<br />in</font><br /><font point-size="19">[chrome.storage.local]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  13 -> 14 [id=97, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Dispatches post-capture<br />media compensation through</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  13 -> 22 [id=98, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Delivers /capture and<br />/visit-events to</font><br /><font point-size="19">[Bearer HTTP/JSON]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  13 -> 15 [id=99, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Records aggregate outbox<br />status through</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
}