digraph {
  compound=true
  graph [fontname="Arial", rankdir=TB, ranksep=1.0, nodesep=1.0]
  node [fontname="Arial", shape=box, margin="0.4,0.3"]
  edge [fontname="Arial"]
  label=<<br /><font point-size="34">Component View: Browser Memory Daemon - Chrome MV3 Extension</font>>

  2 [id=2,shape=rect, label=<<font point-size="34">Windows Chrome</font><br /><font point-size="19">[Software System]</font><br /><br /><font point-size="24">The Windows Chrome runtime<br />that loads web pages, hosts<br />the MV3 extension, runs the<br />local UI in a tab, and exposes<br />Chrome extension APIs.</font>>, style=filled, color="#6b6b6b", fillcolor="#999999", fontcolor="#ffffff"]

  subgraph cluster_4 {
    margin=25
    label=<<font point-size="24"><br />Browser Memory Daemon</font><br /><font point-size="19">[Software System]</font>>
    labelloc=b
    color="#444444"
    fontcolor="#444444"
    fillcolor="#444444"

    subgraph cluster_5 {
      margin=25
      label=<<font point-size="24"><br />Chrome MV3 Extension</font><br /><font point-size="19">[Container: JavaScript, Chrome Manifest V3]</font>>
      labelloc=b
      color="#444444"
      fontcolor="#444444"
      fillcolor="#444444"

      10 [id=10,shape=rect, label=<<font point-size="34">Extension Config<br />Store</font><br /><font point-size="19">[Component: JavaScript + chrome.storage.local]</font><br /><br /><font point-size="24">Owns typed configuration<br />defaults/migration plus<br />durable visit and minimal CDP<br />capture-context maps.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      11 [id=11,shape=rect, label=<<font point-size="34">Visit Tracker</font><br /><font point-size="19">[Component: JavaScript]</font><br /><br /><font point-size="24">Owns tab/navigation identity,<br />active-segment lifecycle<br />state, deterministic lifecycle<br />event identity, and capture<br />decoration.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      12 [id=12,shape=rect, label=<<font point-size="34">Injection Controller</font><br /><font point-size="19">[Component: JavaScript + chrome.scripting]</font><br /><br /><font point-size="24">Reconstructs active-tab<br />injection after worker restart<br />and idempotently injects the<br />complete ordered<br />content-script set.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      13 [id=13,shape=rect, label=<<font point-size="34">Capture and Lifecycle<br />Bridge</font><br /><font point-size="19">[Component: JavaScript]</font><br /><br /><font point-size="24">Owns daemon delivery,<br />transactional outbox<br />import/admission/drain/checkpoint/retry,<br />legacy fallback, media<br />compensation, and queue<br />status.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      14 [id=14,shape=rect, label=<<font point-size="34">Credentialed Media<br />Bridge</font><br /><font point-size="19">[Component: JavaScript]</font><br /><br /><font point-size="24">Owns browser credentialed<br />fetch, inline/CDP blob upload,<br />specialized media queue<br />drain/retry, and terminal<br />cleanup.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      15 [id=15,shape=rect, label=<<font point-size="34">Extension Telemetry</font><br /><font point-size="19">[Component: JavaScript + chrome.storage.local]</font><br /><br /><font point-size="24">Persists aggregate<br />bridge/queue/CDP status after<br />recursively removing captured<br />fields and redacting<br />URL-shaped errors.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      16 [id=16,shape=rect, label=<<font point-size="34">Capture and Lifecycle<br />Outbox</font><br /><font point-size="19">[Component: JavaScript + IndexedDB]</font><br /><br /><font point-size="24">Persists capture and lifecycle<br />messages as independently<br />sequenced IndexedDB rows with<br />atomic<br />enqueue/claim/checkpoint/ack/retry,<br />stale-claim recovery, legacy<br />queue import, item admission<br />limits, and serialized-byte<br />accounting.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      19 [id=19,shape=rect, label=<<font point-size="34">CDP Session<br />Controller</font><br /><font point-size="19">[Component: JavaScript + chrome.debugger]</font><br /><br /><font point-size="24">Restores minimal capture<br />provenance, reconciles<br />debugger attachments,<br />correlates Network events,<br />retrieves bounded bodies, and<br />dispatches media across MV3<br />worker restarts.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      20 [id=20,shape=rect, label=<<font point-size="34">Popup and Options UI</font><br /><font point-size="19">[Component: HTML/JavaScript]</font><br /><br /><font point-size="24">Lets the operator view status,<br />pause/resume capture, select<br />policy mode, and trigger local<br />controls from the extension.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      6 [id=6,shape=rect, label=<<font point-size="34">Manifest and<br />Permission Envelope</font><br /><font point-size="19">[Component: manifest.json]</font><br /><br /><font point-size="24">Declares MV3 permissions, host<br />permissions, service worker,<br />popup, and options<br />entrypoints.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      7 [id=7,shape=rect, label=<<font point-size="34">Extractor</font><br /><font point-size="19">[Component: JavaScript]</font><br /><br /><font point-size="24">Traverses rendered light-DOM<br />text with computed-style and<br />ancestor visibility checks,<br />discovers image/video<br />references, and applies the<br />selected policy mode.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      8 [id=8,shape=rect, label=<<font point-size="34">Content Script</font><br /><font point-size="19">[Component: JavaScript content script]</font><br /><br /><font point-size="24">Schedules initial, delayed,<br />reinjected, and SPA captures;<br />computes full deterministic<br />SHA-256 capture digests;<br />tracks scroll; and sends<br />capture and inline blob upload<br />messages to the service<br />worker.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
      9 [id=9,shape=rect, label=<<font point-size="34">Service Worker</font><br /><font point-size="19">[Component: JavaScript MV3 service worker]</font><br /><br /><font point-size="24">Composes extension modules and<br />registers MV3 message, tab,<br />window, debugger, alarm,<br />startup, and installation<br />listeners.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
    }

    21 [id=21,shape=cylinder, label=<<font point-size="34">Extension Browser<br />Storage</font><br /><font point-size="19">[Container: chrome.storage.local + IndexedDB]</font><br /><br /><font point-size="24">Browser-side IndexedDB storage<br />for transactional<br />capture/lifecycle outbox rows<br />plus specialized durable media<br />tasks/blobs;<br />chrome.storage.local retains<br />typed configuration, lifecycle<br />tab state, minimal CDP capture<br />context, aggregate telemetry,<br />and one-version queue fallback<br />only.</font>>, style=filled, color="#20688c", fillcolor="#2f95c8", fontcolor="#ffffff"]
    22 [id=22,shape=rect, label=<<font point-size="34">WSL Loopback HTTP<br />Daemon</font><br /><font point-size="19">[Container: Python 3.11, ThreadingHTTPServer]</font><br /><br /><font point-size="24">Authenticated loopback HTTP<br />API that handles capture,<br />visit events, media artifact<br />upload/fetch/purge, exact<br />search,<br />recent/timeline/detail, policy<br />rules, doctor, durable forget,<br />and static UI serving.</font>>, style=filled, color="#2e6295", fillcolor="#438dd5", fontcolor="#ffffff"]
  }

  14 -> 22 [id=100, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Delivers media metadata<br />and raw blobs to</font><br /><font point-size="19">[Bearer HTTP/JSON; raw HTTP PUT]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  14 -> 15 [id=102, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Records aggregate media<br />status through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  15 -> 21 [id=104, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Persists sanitized<br />aggregate status in</font><br /><font point-size="19">[chrome.storage.local]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  9 -> 19 [id=105, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Delegates debugger<br />attachment, event<br />correlation, and restart<br />reconciliation to</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  19 -> 10 [id=106, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Persists minimal per-tab<br />capture context through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  19 -> 14 [id=108, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Dispatches bounded CDP<br />media rows and bodies<br />through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  19 -> 15 [id=109, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Records sanitized debugger<br />status through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  20 -> 9 [id=111, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Updates pause, policy,<br />token, and controls<br />through</font><br /><font point-size="19">[chrome.storage.local, runtime messages]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  20 -> 22 [id=112, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Checks health and triggers<br />forget/policy actions on</font><br /><font point-size="19">[HTTP/JSON]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  8 -> 7 [id=82, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Builds capture payloads<br />with</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  8 -> 9 [id=83, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Sends captures and inline<br />blobs to</font><br /><font point-size="19">[chrome.runtime.sendMessage]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  9 -> 10 [id=84, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads typed settings and<br />durable restart state<br />through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  9 -> 11 [id=85, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Delegates navigation<br />identity and lifecycle<br />accounting to</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  9 -> 12 [id=86, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Delegates idempotent<br />active-tab reconstruction<br />to</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  10 -> 21 [id=87, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads and writes typed<br />settings and restart state<br />in</font><br /><font point-size="19">[chrome.storage.local]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  11 -> 10 [id=88, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Persists tab/navigation<br />lifecycle state through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  12 -> 2 [id=89, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Injects the ordered<br />extractor/digest/content-script<br />set into</font><br /><font point-size="19">[chrome.scripting]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  9 -> 13 [id=90, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Delegates<br />capture/lifecycle delivery<br />and durable drains to</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  9 -> 14 [id=91, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Delegates credentialed<br />media delivery and durable<br />drains to</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  9 -> 15 [id=92, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Creates the redaction-safe<br />telemetry boundary through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  13 -> 16 [id=93, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Enqueues, drains,<br />checkpoints, retries, and<br />recovers capture/lifecycle<br />work through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  13 -> 21 [id=94, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Imports and preserves the<br />one-version queue fallback<br />in</font><br /><font point-size="19">[chrome.storage.local]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  13 -> 14 [id=95, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Dispatches post-capture<br />media compensation through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  13 -> 22 [id=96, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Delivers /capture and<br />/visit-events to</font><br /><font point-size="19">[Bearer HTTP/JSON]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  13 -> 15 [id=97, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Records aggregate outbox<br />status through</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]
  16 -> 21 [id=98, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads and writes sequenced<br />capture/lifecycle rows and<br />migration metadata in</font><br /><font point-size="19">[IndexedDB]</font></TD></TR></TABLE>>, style="dashed", color="#444444", fontcolor="#444444"]

}