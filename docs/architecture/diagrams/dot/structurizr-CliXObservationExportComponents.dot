    52 [id=52,shape=rect, label=<<font point-size="34">CLI X Observation<br />Export Adapter</font><br /><font point-size="19">[Component: Python + sqlite3]</font><br /><br /><font point-size="24">Opens the existing database<br />directly through the shared<br />query-only export core without<br />daemon readiness, migrations,<br />token requirements, or audit<br />writes.</font>>, style=filled, color="#1168bd", fillcolor="#85bbf0", fontcolor="#000000"]
  }

  52 -> 57 [id=193, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Reads validated<br />observation/evidence pages<br />without writes or audit</font><br /><font point-size="19">[SQLite mode=ro + query_only]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
  52 -> 4 [id=194, label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="white"><TR><TD><font point-size="24">Emits losslessly<br />cursorable body-safe pages<br />for</font><br /><font point-size="19">[JSON stdout]</font></TD></TR></TABLE>>, style="dashed", color="#707070", fontcolor="#707070"]
