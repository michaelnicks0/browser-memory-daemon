# Copy to a local ignored .env if desired.
# Do not commit real tokens.
BMD_API_TOKEN=replace-with-local-token
BMD_PORT=8765
BMD_HOST=127.0.0.1
BMD_POLICY_MODE=all
BMD_RUNTIME_ROOT=~/.local/share/browser-memory-daemon
BMD_BLOB_ROOT=~/.local/share/browser-memory-daemon/blobs
# Hybrid final-media root plus bounded local outage spool example:
# BMD_DERIVATIVE_ROOT=~/.local/share/browser-memory-daemon/derivatives
# BMD_MEDIA_ROOT=/mnt/nas/browser-memory-daemon/blobs/media
# BMD_MEDIA_ROOT_IDENTITY=bmd-media-prod
# BMD_REQUIRE_MEDIA_ROOT_MOUNT=1
# BMD_MEDIA_SPOOL_ROOT=~/.local/share/browser-memory-daemon/media-spool
# BMD_MAX_MEDIA_SPOOL_BYTES=21474836480
